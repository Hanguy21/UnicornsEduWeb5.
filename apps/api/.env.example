DATABASE_URL="database-url"
PORT=3001
BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Bắt buộc để gửi email xác thực (đăng ký) và quên mật khẩu. Nếu không cấu hình, đăng ký sẽ trả lỗi 503.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-pass"
SMTP_SECURE=false
MAIL_FROM="no-reply@example.com"

# Google OAuth (đăng nhập bằng Google). Redirect URI trong Google Console: BACKEND_URL/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

JWT_EMAIL_VERIFY_SECRET="a"
JWT_FORGOT_PASSWORD_SECRET="a"
JWT_ACCESS_SECRET="a"
JWT_REFRESH_SECRET="a"

# Codeforces API (group contests, problems). Lấy tại https://codeforces.com/settings/api
CODEFORCES_API_KEY=""
CODEFORCES_API_SECRET=""
# 3 nhóm tài liệu (Tab Tài liệu)
CODEFORCES_GROUP_LUYEN_TAP="QMLH5CiNY0"
CODEFORCES_GROUP_KHAO_SAT="thwM5mnACt"
CODEFORCES_GROUP_THUC_CHIEN="iBXOT8i9ss"
# Website link tương ứng mỗi group (để mở bài trong group)
CODEFORCES_WEBSITE_LUYEN_TAP="http://unicornsedu.contest.codeforces.com"
CODEFORCES_WEBSITE_KHAO_SAT="http://unicornseduexam.contest.codeforces.com"
