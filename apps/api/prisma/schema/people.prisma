// ============================================
// STAFF INFO
// ============================================
model StaffInfo {
  id             String      @id
  fullName       String      @map("full_name")
  birthDate      DateTime?   @map("birth_date") @db.Date
  university     String?
  highSchool     String?     @map("high_school")
  specialization String?
  bankAccount    String?     @map("bank_account")
  bankQrLink     String?     @map("bank_qr_link")
  roles          Json        @default("[]")
  status         StaffStatus @default(active)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  users                User[]
  classTeachers        ClassTeacher[]
  sessions             Session[]
  bonuses              Bonus[]
  lessonOutputs        LessonOutput[]
  customerCareServices CustomerCareService[]
  walletTransactions   WalletTransactionsHistory[] @relation("CustomerCareStaff")
  monthlyStats         StaffMonthlyStat[]
  classSurveys         ClassSurvey[]
  staffLessonTasks     StaffLessonTask[] 

  @@map("staff_info")
}

// ============================================
// STUDENT INFO
// ============================================
model StudentInfo {
  id          String        @id
  fullName    String        @map("full_name")
  email       String?
  school      String?
  province    String?
  birthYear   Int?          @map("birth_year")
  parentName  String?       @map("parent_name")
  parentPhone String?       @map("parent_phone")
  status      StudentStatus @default(active)
  gender      Gender        @default(male)
  goal        String?
  dropOutDate DateTime?     @map("drop_out_date") @db.Date
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  users                User[]
  studentClasses       StudentClass[]
  attendanceRecords    Attendance[]
  walletTransactions   WalletTransactionsHistory[]
  customerCareServices CustomerCareService[]

  @@map("student_info")
}
